{
  "name": "vidura",
  "version": "0.1.3",
  "description": "Local-first desktop app to chat with your documents privately, with no file limits",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w @lancedb/lancedb",
    "eval": "tsx eval/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src eval",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "prepare": "husky",
    "llama:update": "npx --no node-llama-cpp source download --release b8750 --skipBuild && node scripts/patch-llama.js && npx --no node-llama-cpp source build",
    "dist:mac": "npm run llama:update && npm run build && bash scripts/package-mac.sh; npm install",
    "langfuse:start": "docker compose -f scripts/langfuse.docker-compose.yml up -d",
    "langfuse:stop": "docker compose -f scripts/langfuse.docker-compose.yml down"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint"
    ],
    "*.{js,mjs,json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.2",
    "electron-vite": "^2.3.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.22.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.6",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.27.2",
    "apache-arrow": "^18.1.0",
    "chokidar": "^3.6.0",
    "langfuse": "^2.8.0",
    "node-llama-cpp": "^3.18.1",
    "pdfjs-dist": "^5.7.284",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.26.9"
  }
}
